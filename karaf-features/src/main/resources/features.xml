<?xml version="1.0" encoding="UTF-8"?>
<features name="prometheus-remote-writer-${project.version}"
          xmlns="http://karaf.apache.org/xmlns/features/v1.6.0">

    <feature name="prometheus-remote-writer"
             description="OpenNMS TSS plugin: writes samples to Prometheus-compatible Remote Write endpoints"
             version="${project.version}">

        <!-- Pull in the OpenNMS Integration API feature so its api + common
             + utils bundles are installed before ours and their packages
             are visible to the resolver. Without this prereq, our bundle
             fails to wire the org.opennms.integration.api.v1.timeseries*
             packages at install time even though the bundles are sitting
             in Karaf's system repository. -->
        <feature version="2.0.0">opennms-integration-api</feature>

        <!-- Config file shipped into etc/ on install -->
        <configfile finalname="${karaf.etc}/org.opennms.plugins.tss.prometheusremotewriter.cfg"
                    override="false">
            mvn:org.opennms.plugins/prometheus-remote-writer/${project.version}/cfg/config
        </configfile>

        <!-- The plugin bundle itself. Runtime deps (OkHttp, snappy, protobuf,
             dropwizard metrics) are embedded inside the bundle, so no additional
             <bundle> entries are required here. -->
        <bundle start-level="80">
            mvn:org.opennms.plugins/prometheus-remote-writer/${project.version}
        </bundle>

    </feature>

</features>
