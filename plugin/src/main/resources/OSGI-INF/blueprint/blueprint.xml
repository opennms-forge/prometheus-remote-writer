<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.3.0"
           xsi:schemaLocation="
             http://www.osgi.org/xmlns/blueprint/v1.0.0
               https://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd
             http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.3.0
               http://aries.apache.org/schemas/blueprint-cm/blueprint-cm-1.3.0.xsd">

    <!--
        Configuration binding. ConfigAdmin PID matches the properties file at
        etc/org.opennms.plugins.tss.prometheusremotewriter.cfg so that Karaf
        picks up changes on file save and hot-reloads the plugin config.
        The PID / filename is deliberately dashless — Felix fileinstall
        parses "<prefix>-<instance>.cfg" as a factory-PID config.
    -->
    <cm:property-placeholder persistent-id="org.opennms.plugins.tss.prometheusremotewriter"
                             update-strategy="reload">
        <cm:default-properties>
            <!-- Endpoint -->
            <cm:property name="write.url" value=""/>
            <cm:property name="read.url"  value=""/>
            <!-- Source identity -->
            <cm:property name="instance.id" value=""/>
            <cm:property name="job.name"    value=""/>
            <!-- Auth -->
            <cm:property name="auth.basic.username" value=""/>
            <cm:property name="auth.basic.password" value=""/>
            <cm:property name="auth.bearer.token"   value=""/>
            <cm:property name="tenant.org-id"       value=""/>
            <!-- TLS -->
            <cm:property name="tls.ca-file"               value=""/>
            <cm:property name="tls.insecure-skip-verify"  value="false"/>
            <!-- Write pipeline -->
            <cm:property name="queue.capacity"            value="10000"/>
            <cm:property name="batch.size"                value="1000"/>
            <cm:property name="flush.interval-ms"         value="1000"/>
            <cm:property name="retry.max-attempts"        value="5"/>
            <cm:property name="retry.initial-backoff-ms"  value="250"/>
            <cm:property name="retry.max-backoff-ms"      value="10000"/>
            <!-- HTTP -->
            <cm:property name="http.connect-timeout-ms"   value="5000"/>
            <cm:property name="http.read-timeout-ms"      value="30000"/>
            <cm:property name="http.write-timeout-ms"     value="30000"/>
            <cm:property name="http.max-connections"      value="16"/>
            <!-- Shutdown -->
            <cm:property name="shutdown.grace-period-ms"  value="10000"/>
            <!-- Read path -->
            <cm:property name="max-series-lookback-seconds" value="7776000"/>
            <!-- Label policy -->
            <cm:property name="labels.include" value=""/>
            <cm:property name="labels.exclude" value=""/>
            <cm:property name="labels.rename"  value=""/>
            <cm:property name="labels.copy"    value=""/>
            <cm:property name="metric.prefix"  value=""/>
            <!-- Metadata passthrough -->
            <cm:property name="metadata.enabled"       value="false"/>
            <cm:property name="metadata.include"       value=""/>
            <cm:property name="metadata.exclude"       value=""/>
            <cm:property name="metadata.label-prefix"  value="onms_meta_"/>
            <cm:property name="metadata.case"          value="preserve"/>
        </cm:default-properties>
    </cm:property-placeholder>

    <!--
        Configuration holder. Reads every placeholder above and exposes an
        immutable PrometheusRemoteWriterConfig to downstream beans.
    -->
    <bean id="config"
          class="org.opennms.plugins.prometheus.remotewriter.config.PrometheusRemoteWriterConfig">
        <property name="writeUrl"                value="${write.url}"/>
        <property name="readUrl"                 value="${read.url}"/>
        <property name="instanceId"              value="${instance.id}"/>
        <property name="jobName"                 value="${job.name}"/>
        <property name="basicUsername"           value="${auth.basic.username}"/>
        <property name="basicPassword"           value="${auth.basic.password}"/>
        <property name="bearerToken"             value="${auth.bearer.token}"/>
        <property name="tenantOrgId"             value="${tenant.org-id}"/>
        <property name="tlsCaFile"               value="${tls.ca-file}"/>
        <property name="tlsInsecureSkipVerify"   value="${tls.insecure-skip-verify}"/>
        <property name="queueCapacity"           value="${queue.capacity}"/>
        <property name="batchSize"               value="${batch.size}"/>
        <property name="flushIntervalMs"         value="${flush.interval-ms}"/>
        <property name="retryMaxAttempts"        value="${retry.max-attempts}"/>
        <property name="retryInitialBackoffMs"   value="${retry.initial-backoff-ms}"/>
        <property name="retryMaxBackoffMs"       value="${retry.max-backoff-ms}"/>
        <property name="httpConnectTimeoutMs"    value="${http.connect-timeout-ms}"/>
        <property name="httpReadTimeoutMs"       value="${http.read-timeout-ms}"/>
        <property name="httpWriteTimeoutMs"      value="${http.write-timeout-ms}"/>
        <property name="httpMaxConnections"      value="${http.max-connections}"/>
        <property name="shutdownGracePeriodMs"    value="${shutdown.grace-period-ms}"/>
        <property name="maxSeriesLookbackSeconds" value="${max-series-lookback-seconds}"/>
        <property name="labelsInclude"           value="${labels.include}"/>
        <property name="labelsExclude"           value="${labels.exclude}"/>
        <property name="labelsRename"            value="${labels.rename}"/>
        <property name="labelsCopy"              value="${labels.copy}"/>
        <property name="metricPrefix"            value="${metric.prefix}"/>
        <property name="metadataEnabled"         value="${metadata.enabled}"/>
        <property name="metadataInclude"         value="${metadata.include}"/>
        <property name="metadataExclude"         value="${metadata.exclude}"/>
        <property name="metadataLabelPrefix"     value="${metadata.label-prefix}"/>
        <property name="metadataCase"            value="${metadata.case}"/>
    </bean>

    <!--
        The TimeSeriesStorage service. OpenNMS discovers it through the
        integration-api service registry and uses it as the active TSS when
        org.opennms.timeseries.strategy=integration.
    -->
    <bean id="prometheusRemoteWriterStorage"
          class="org.opennms.plugins.prometheus.remotewriter.PrometheusRemoteWriterStorage"
          init-method="start"
          destroy-method="stop">
        <argument ref="config"/>
    </bean>

    <service ref="prometheusRemoteWriterStorage"
             interface="org.opennms.integration.api.v1.timeseries.TimeSeriesStorage">
        <service-properties>
            <entry key="registration.export" value="true"/>
        </service-properties>
    </service>

    <!--
        Karaf shell command: opennms:prometheus-writer-stats
        Karaf's shell runtime picks up Action services whose @Command scope/name
        match what the user types.
    -->
    <bean id="statsCommand"
          class="org.opennms.plugins.prometheus.remotewriter.shell.StatsCommand">
        <property name="storage" ref="prometheusRemoteWriterStorage"/>
    </bean>
    <service ref="statsCommand" interface="org.apache.karaf.shell.api.action.Action"/>

</blueprint>
